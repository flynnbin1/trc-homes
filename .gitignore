# Temporary screenshots stay local — never uploaded to GitHub
temp_screenshots/*
!temp_screenshots/.gitkeep

# Dependencies (if Puppeteer is installed later for screenshots)
node_modules/

# OS clutter
.DS_Store
Thumbs.db

# Firecrawl search cache (tool output — not part of the site)
.firecrawl/

# Hero video: keep the runtime frame tiers (frames-hd/, frames-mobile/) but
# NOT the heavy source clips or intermediate/superseded frame sets — those
# stay local (only needed to regenerate frames), out of git history.
assets/hero-video/*.mp4
assets/hero-video/frames/
assets/keyframes/kling/

# Portrait/mobile source media — filed locally, not used by the live site yet.
# Keep out of git history (raw stills + clips are heavy); commit only if a
# mobile hero actually ships them.
assets/hero-video/mobile/
assets/keyframes/source/

# Raw source clips & stills in assets/ root — heavy AI-generated source media
# (Higgsfield exports + build/interior stills) used only to produce the
# committed hero frames/keyframes. Kept local, out of git history — mirrors the
# hero-video/ and keyframes/ source rules above. Note: the committed
# assets/how-it-works-timelapse.mp4 is deliberately NOT matched by these.
assets/hero-timeline-trc.mp4
assets/hf_*.mp4
assets/clip*.jpeg

# Local Claude session handoff notes — dev aid, not part of the website.
SESSION-HANDOFF.md
