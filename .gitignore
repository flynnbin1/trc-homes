# Temporary screenshots stay local — never uploaded to GitHub
temp_screenshots/*
!temp_screenshots/.gitkeep

# Dependencies (if Puppeteer is installed later for screenshots)
node_modules/

# OS clutter
.DS_Store
Thumbs.db

# Hero video: keep the runtime frame tiers (frames-hd/, frames-mobile/) but
# NOT the heavy source clips or intermediate/superseded frame sets — those
# stay local (only needed to regenerate frames), out of git history.
assets/hero-video/*.mp4
assets/hero-video/frames/
assets/keyframes/kling/
